# --- HTTP server ---
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/acdp_control_plane
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# --- Auth ---
# Comma-separated API keys. Empty in dev = auth disabled.
AUTH_API_KEYS=

# --- Ingest ---
# HMAC-SHA256 secret used to verify incoming registry webhooks. Empty = skip (dev).
WEBHOOK_SECRET=

# --- Playground ---
PLAYGROUND_URL=

# --- Stream hub ---
STREAM_HUB_STRATEGY=memory
REDIS_URL=
STREAM_SSE_HEARTBEAT_MS=15000

# --- Throttler ---
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=200

# --- Data retention ---
DATA_RETENTION_ENABLED=false
DATA_RETENTION_TTL_DAYS=30
DATA_RETENTION_INTERVAL_HOURS=24

# --- OpenTelemetry / logging ---
LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_SERVICE_NAME=acdp-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=

NODE_ENV=development
